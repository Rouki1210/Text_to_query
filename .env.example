# Copy to .env and fill in the secrets:  cp .env.example .env
# Every value here is read by src/fsq_agent/config.py via pydantic-settings.
# .env is gitignored — never commit real keys.

# ---------------------------------------------------------------- LLM
LLM_PROVIDER=anthropic
# Current model IDs: claude-opus-4-8 (most capable), claude-sonnet-5
# (cheaper, good for high-volume eval runs), claude-haiku-4-5 (fastest).
LLM_MODEL=claude-haiku-4-5
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: OpenAI-compatible proxy / gateway. Leave empty to call
# api.anthropic.com directly.
LLM_BASE_URL=
# Ceiling per completion. Reasoning models spend this on thinking before
# writing any SQL, so a low value truncates hard questions before they answer.
# It is a cap, not a reservation — you pay for tokens produced, not the cap.
LLM_MAX_TOKENS=16000

# ---------------------------------------------------------------- Database
# Dev: local DuckDB mock built by `python scripts/seed_mock_data.py`.
# Prod: point at the real warehouse, e.g.
#   DATABASE_URL=postgresql+psycopg://user:pass@host/feature_store
DATABASE_URL=duckdb:///data/mock/feature_store.duckdb
# Schema the agent queries. Point this at the sanitised views built by
#   python scripts/generate_safe_views.py
# so credential columns are absent from the data the agent can reach at all,
# rather than only being filtered afterwards. It becomes the connection's
# whole search_path, so a table without a view fails to resolve — that is
# deliberate. Leave empty for DuckDB.
DB_SCHEMA=fsq_safe
# Hard row cap appended to every generated query by sql/guards.py.
QUERY_ROW_LIMIT=500
QUERY_TIMEOUT_SECONDS=30

# ---------------------------------------------------------------- Reporter (Sprint 3)
# Leave empty to dry-run the nightly report to stdout instead of posting.
SLACK_WEBHOOK_URL=
# A metric must clear BOTH thresholds to become a Finding.
ZSCORE_THRESHOLD=2.0
MIN_PCT_CHANGE=0.15

# ---------------------------------------------------------------- Safety
# Columns the agent may never read. Hidden from the prompt AND rejected by
# sql/guards.py if a generated query names one anyway. Matched on whole words,
# case-insensitively, across every table — so add composite variants
# (e.g. user_email) explicitly if your schema uses them.
# Uncomment to override the defaults in config.py.
# SENSITIVE_COLUMNS=PasswordHash,Password,Email,WalletAddress,NonceValue,Birthday,Token,Secret,ApiKey,Ssn
